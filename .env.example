# ═══════════════════════════════════════════════════════════
# 企业知识库智能问答系统 — 环境变量配置模板
# 复制此文件为 .env 并填入真实密钥
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── DeepSeek LLM（必填）──────────────────────────────
DEEPSEEK_API_KEY=sk-your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FREE_MODEL=deepseek-chat
DEEPSEEK_V4_MODEL=deepseek-v4-flash
DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro
LLM_TIMEOUT=180

# ── DashScope 阿里云（Embedding + 视觉模型）──────────
DASHSCOPE_API_KEY=sk-your_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v2
EMBED_API_KEY=sk-your_key_here
QWEN_FREE_MODEL=qwen-vl-plus

# ── RAGFlow 文档引擎 ──────────────────────────────────
RAGFLOW_BASE_URL=http://localhost
RAGFLOW_API_KEY=ragflow-your_key_here
USE_RAGFLOW=true

# ── Qdrant Cloud 向量数据库（RAGFlow 离线降级用）─────
QDRANT_URL=https://your-instance.qdrant.cloud
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=kb_vectors
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# ── MySQL（元数据 / 聊天记录 / 评估数据）──────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=kb_qa_system

# ── Neo4j 知识图谱（可选）─────────────────────────────
NEO4J_URI=neo4j+s://your_instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# ── 应用设置 ──────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
SCORE_THRESHOLD=0.3
